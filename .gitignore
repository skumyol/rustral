# ============================================================================
# Rust Build Artifacts
# ============================================================================
/target
**/target
**/debug/
**/release/
*.rlib
*.rmeta
*.so
*.dylib
*.dll
*.d
*.pdb

# ============================================================================
# Rust Backup & Generated
# ============================================================================
**/*.rs.bk
# Cargo.lock is tracked because the workspace ships binaries (runtime examples,
# benchmark binaries) and we want fully reproducible clones.
*.rs~*

# ============================================================================
# IDE / Editor
# ============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
*.bak

# ============================================================================
# OS Files
# ============================================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================================
# Logs & Temp
# ============================================================================
*.log
*.tmp
*.temp
tmp/
temp/

# ============================================================================
# Data / Models / Checkpoints
# ============================================================================
/data/
!/data/.gitkeep
*.csv
*.bin
*.onnx
*.pt
*.pth
*.safetensors
*.h5
*.hdf5
*.npz
*.npy
checkpoints/
models/
datasets/
# Allow the in-tree dataset loader modules to be tracked even though we ignore
# `datasets/` for downloaded artifacts. Without this the rustral-data fetch loaders
# go missing on a fresh clone.
!crates/data/src/datasets/
!crates/data/src/datasets/**/*.rs

# ============================================================================
# Environment & Secrets
# ============================================================================
.env
.env.local
.env.*.local
secrets.toml
*.pem
*.key

# ============================================================================
# Devin / Local Config
# ============================================================================
.devin/config.local.json
.devin/summaries/
.devin/logs/

# ============================================================================
# Python (if mixed project)
# ============================================================================
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.venv/
venv/

# ============================================================================
# Profiling / Coverage
# ============================================================================
*.prof
coverage/
*.gcda
*.gcno

# ============================================================================
# Legacy / Docs (project-specific)
# ============================================================================
legacy/
docs/legacy-mapping.md
rustral_logo_assets.zip
scripts/publish_crates_io.sh
vendor/*
IMPROVEMENT_PLAN.md
docs/assets/rustral_system_diagram_download.zip
docs/assets/rustral_system_diagram_download/

# EMNLP demo determinism reports (generated)
emnlp_determinism_report.json
benchmarks/results/
benchmarks/queue_logs/
# Benchmark run results (generated)
benchmarks/runs/*/nlp/*/seed_*/
benchmarks/runs/*/manifest.json

# Pages dashboard output: rendered locally for previewing only; the deployed copy is
# rebuilt by .github/workflows/pages.yml on every push.
docs/site/
out/

.venv-golden/
