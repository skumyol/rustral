{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Rustral NLP curated run schema",
  "type": "object",
  "required": ["schema_version", "created_at", "version", "task", "metric", "aggregate", "runs"],
  "properties": {
    "schema_version": { "type": "integer" },
    "created_at": { "type": "string" },
    "version": { "type": "string" },
    "task": { "type": "string" },
    "metric": { "type": "string" },
    "aggregate": {
      "type": "object",
      "required": ["mean", "std", "n"],
      "properties": {
        "mean": { "type": "number" },
        "std": { "type": "number" },
        "n": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    },
    "runs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["seed", "manifest"],
        "properties": {
          "seed": { "type": "integer" },
          "out_dir": { "type": "string" },
          "manifest": { "type": "object" }
        },
        "additionalProperties": true
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "task": { "const": "sst2_classifier" } }
      },
      "then": {
        "properties": {
          "runs": {
            "items": {
              "properties": {
                "manifest": {
                  "type": "object",
                  "anyOf": [
                    {
                      "properties": {
                        "framework": { "const": "pytorch" }
                      }
                    },
                    {
                      "required": ["diagnostics"],
                      "properties": {
                        "diagnostics": {
                          "type": "object",
                          "required": [
                            "train_label_counts",
                            "dev_label_counts",
                            "dev_confusion_matrix",
                            "dev_predicted_counts",
                            "dev_positive_prob_hist"
                          ],
                          "properties": {
                            "train_label_counts": {
                              "type": "array",
                              "items": { "type": "integer", "minimum": 0 },
                              "minItems": 2,
                              "maxItems": 2
                            },
                            "dev_label_counts": {
                              "type": "array",
                              "items": { "type": "integer", "minimum": 0 },
                              "minItems": 2,
                              "maxItems": 2
                            },
                            "dev_confusion_matrix": {
                              "type": "array",
                              "minItems": 2,
                              "maxItems": 2,
                              "items": {
                                "type": "array",
                                "minItems": 2,
                                "maxItems": 2,
                                "items": { "type": "integer", "minimum": 0 }
                              }
                            },
                            "dev_predicted_counts": {
                              "type": "array",
                              "items": { "type": "integer", "minimum": 0 },
                              "minItems": 2,
                              "maxItems": 2
                            },
                            "dev_positive_prob_hist": {
                              "type": "object",
                              "required": ["bins", "counts"],
                              "properties": {
                                "bins": { "type": "integer", "minimum": 2 },
                                "counts": {
                                  "type": "array",
                                  "items": { "type": "integer", "minimum": 0 },
                                  "minItems": 2
                                }
                              },
                              "additionalProperties": true
                            }
                          },
                          "additionalProperties": true
                        }
                      }
                    }
                  ],
                  "additionalProperties": true
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "task": { "const": "llm_generate" } }
      },
      "then": {
        "properties": {
          "runs": {
            "items": {
              "properties": {
                "manifest": {
                  "type": "object",
                  "required": [
                    "framework",
                    "task",
                    "git_sha",
                    "model_id",
                    "seed",
                    "hub_snapshot_ms",
                    "model_init_ms",
                    "tokenizer_load_ms",
                    "tokenizer_hash_fnv1a",
                    "prompt_fnv1a",
                    "prompt_tokens",
                    "max_new_tokens",
                    "first_token_ms",
                    "decode_wall_ms"
                  ],
                  "properties": {
                    "framework": { "const": "rustral_llm" },
                    "task": { "const": "llm_generate" },
                    "git_sha": { "type": "string", "minLength": 4 },
                    "model_id": { "type": "string", "minLength": 1 },
                    "backend": { "type": "string" },
                    "dtype": { "type": "string" },
                    "seed": { "type": "integer", "minimum": 0 },
                    "hub_snapshot_ms": { "type": "number" },
                    "model_init_ms": { "type": "number" },
                    "tokenizer_load_ms": { "type": "number" },
                    "tokenizer_hash_fnv1a": { "type": "string", "minLength": 4 },
                    "prompt_fnv1a": { "type": "string", "minLength": 4 },
                    "prompt_tokens": { "type": "integer", "minimum": 1 },
                    "max_new_tokens": { "type": "integer", "minimum": 0 },
                    "generated_new_tokens": { "type": "integer", "minimum": 0 },
                    "first_token_ms": { "type": "number" },
                    "decode_wall_ms": { "type": "number" },
                    "tokens_per_sec": { "type": ["number", "null"] }
                  },
                  "additionalProperties": true
                }
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": true
}

